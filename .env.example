VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" to use local Firebase emulators (run: npm run firebase:emulators)
VITE_USE_FIREBASE_EMULATORS=false

# AI features call the `aiAssist` Cloud Function (OpenAI). They require the function to be
# deployed (Blaze plan) with the OPENAI_API_KEY secret set. The app works fully with these
# off and falls back to deterministic behavior when AI is disabled, undeployed, or over quota.

# Post-session AI tutor (summary + scoped chat).
VITE_ENABLE_AI_TUTOR=true
